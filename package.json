{
  "name": "contact-snap",
  "version": "1.0.0",
  "productName": "Contact Snap",
  "description": "Snap photos, save contacts instantly",
  "main": "out/main/index.js",
  "author": "Mike Shear",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "type-check": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.3"
  },
  "build": {
    "afterPack": "./scripts/after-pack.js",
    "appId": "com.mikeshear.contact-snap",
    "productName": "Contact Snap",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": {
        "teamId": "95E9CZ9HW6"
      }
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "resources/tray-icon.png", "to": "tray-icon.png" },
      { "from": "resources/tray-icon@2x.png", "to": "tray-icon@2x.png" }
    ],
    "directories": {
      "buildResources": "resources",
      "output": "/tmp/contact-snap-dist"
    }
  }
}
