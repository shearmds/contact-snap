<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's V8 JIT compiler under Hardened Runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Required for Electron's code execution model -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required to load Electron's own native libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Outbound network access (Cloudflare Worker + Gemini API) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Send Apple Events to Contacts.app via osascript -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    <!-- Read/write Contacts (may be required depending on macOS version) -->
    <key>com.apple.security.personal-information.addressbook</key>
    <true/>
  </dict>
</plist>
